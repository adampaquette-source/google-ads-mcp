# Project config
ADS_MCP_ENV=local
ADS_MCP_AUDIT_LOG_PATH=./audit.db

# Control center (optional): dedicated Chat space webhook for flag alerts.
# Falls back to GOOGLE_CHAT_WEBHOOK_URL when unset.
GOOGLE_ADS_CC_WEBHOOK_URL=

# Control center hosted mode (Railway only -- never needed locally).
# PORT is injected by Railway and switches the app into hosted mode:
# 0.0.0.0 binding, Google OAuth in front, view-only enforced.
# GOOGLE_OAUTH_CLIENT_ID=            same Google client as the MCP connectors
# GOOGLE_OAUTH_CLIENT_SECRET=
# ADS_CC_BASE_URL=                   https://<railway-domain>, no trailing slash
# ADS_CC_SESSION_SECRET=             fresh per service: openssl rand -hex 32
# ADS_CC_ROLE_MAP=                   {"adam.paquette@pcstools.com": "admin"}
# ADS_CC_DB_PATH=/data/control_center.db
# ADS_CC_DASHBOARD_URL=              public URL used in Chat alert links
# ADS_CC_SCHEDULER=1                 0 disables the in-process pull scheduler
# TZ=America/Los_Angeles             pull times + cooldowns assume Pacific
